{
  "rules": {
    ".read": false,
    ".write": false,

    "rooms": {
      ".indexOn": ["createdAt"],

      "$roomCode": {
        ".read": "auth != null",

        ".write": "auth != null && !data.exists() && newData.child('hostId').val() === auth.uid",
        ".validate": "newData.hasChildren(['code','hostId','hostDisplayName','createdAt','ended']) && newData.child('code').val() === $roomCode && newData.child('code').val().length === 4 && newData.child('hostDisplayName').isString() && newData.child('hostDisplayName').val().length >= 1 && newData.child('hostDisplayName').val().length <= 50 && newData.child('createdAt').isNumber() && newData.child('ended').isBoolean()",

        "ended": {
          ".write": "auth != null && auth.uid === root.child('rooms').child($roomCode).child('hostId').val()",
          ".validate": "newData.isBoolean()"
        },

        "playback": {
          ".write": "auth != null && auth.uid === root.child('rooms').child($roomCode).child('hostId').val()",
          ".validate": "newData.hasChildren(['trackUri','trackName','artistName','isPlaying','positionMs','updatedAt']) && newData.child('trackUri').isString() && newData.child('trackUri').val().length <= 200 && newData.child('trackName').isString() && newData.child('trackName').val().length <= 200 && newData.child('artistName').isString() && newData.child('artistName').val().length <= 200 && (!newData.hasChild('albumArt') || (newData.child('albumArt').isString() && newData.child('albumArt').val().length <= 500)) && newData.child('isPlaying').isBoolean() && newData.child('positionMs').isNumber() && newData.child('positionMs').val() >= 0 && newData.child('updatedAt').isNumber()"
        },

        "listeners": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['displayName','joinedAt']) && newData.child('displayName').isString() && newData.child('displayName').val().length >= 1 && newData.child('displayName').val().length <= 50 && newData.child('joinedAt').isNumber()"
          }
        },

        "chat": {
          "$messageId": {
            ".write": "auth != null && !data.exists() && newData.child('uid').val() === auth.uid",
            ".validate": "newData.hasChildren(['uid','displayName','text','sentAt']) && newData.child('displayName').isString() && newData.child('displayName').val().length >= 1 && newData.child('displayName').val().length <= 50 && newData.child('text').isString() && newData.child('text').val().length >= 1 && newData.child('text').val().length <= 500 && newData.child('sentAt').isNumber()"
          }
        }
      }
    },

    "likes": {
      "$fromUid": {
        ".read": "auth != null && auth.uid === $fromUid",
        "$toUid": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid === $fromUid",
          ".validate": "newData.isBoolean()"
        }
      }
    },

    "passed": {
      "$fromUid": {
        ".read": "auth != null && auth.uid === $fromUid",
        "$toUid": {
          ".write": "auth != null && auth.uid === $fromUid",
          ".validate": "newData.isBoolean()"
        }
      }
    },

    "matches": {
      ".read": "auth != null",

      "$matchId": {
        ".write": "auth != null && !data.exists() && (newData.child('user1').val() === auth.uid || newData.child('user2').val() === auth.uid)",
        ".validate": "newData.hasChildren(['user1','user2','score','createdAt']) && newData.child('user1').isString() && newData.child('user2').isString() && newData.child('score').isNumber() && newData.child('score').val() >= 0 && newData.child('score').val() <= 100 && newData.child('createdAt').isNumber()",

        "pfpShared": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.isString() && newData.val().length <= 500"
          }
        },

        "chat": {
          "$messageId": {
            ".write": "auth != null && !data.exists() && newData.child('uid').val() === auth.uid",
            ".validate": "newData.hasChildren(['uid','displayName','text','sentAt']) && newData.child('displayName').isString() && newData.child('displayName').val().length >= 1 && newData.child('displayName').val().length <= 50 && newData.child('text').isString() && newData.child('text').val().length >= 1 && newData.child('text').val().length <= 1000 && newData.child('sentAt').isNumber()"
          }
        }
      }
    },

    "users": {
      ".read": "auth != null",

      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['nickname','createdAt']) && newData.child('nickname').isString() && newData.child('nickname').val().length >= 1 && newData.child('nickname').val().length <= 50 && newData.child('createdAt').isNumber() && (!newData.hasChild('isPublic') || newData.child('isPublic').isBoolean())",

        "ratings": {
          "$trackId": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['trackUri','trackName','artistName','rating','ratedAt']) && newData.child('trackUri').isString() && newData.child('trackName').isString() && newData.child('artistName').isString() && newData.child('rating').isNumber() && newData.child('rating').val() >= 1 && newData.child('rating').val() <= 10 && newData.child('ratedAt').isNumber()"
          }
        }
      }
    },

    "friends": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$friendId": {
          ".write": "auth != null && (auth.uid === $uid || auth.uid === $friendId)",
          ".validate": "newData.hasChildren(['uid','nickname','addedAt']) && newData.child('uid').isString() && newData.child('nickname').isString() && newData.child('addedAt').isNumber()"
        }
      }
    },

    "friendRequests": {
      "$toUid": {
        ".read": "auth != null && auth.uid === $toUid",
        "$fromUid": {
          ".write": "auth != null && (auth.uid === $fromUid || auth.uid === $toUid)",
          ".validate": "!newData.exists() || (newData.hasChildren(['fromUid','nickname','sentAt']) && newData.child('fromUid').isString() && newData.child('nickname').isString() && newData.child('sentAt').isNumber())"
        }
      }
    },

    "dms": {
      "$dmId": {
        ".read": "auth != null && data.child('info/participants').hasChild(auth.uid)",

        "info": {
          ".write": "auth != null && newData.child('participants').hasChild(auth.uid)",
          ".validate": "newData.hasChildren(['participants','createdAt']) && newData.child('createdAt').isNumber()"
        },

        "messages": {
          "$msgId": {
            ".write": "auth != null && !data.exists() && newData.child('uid').val() === auth.uid && root.child('dms').child($dmId).child('info/participants').hasChild(auth.uid)",
            ".validate": "newData.hasChildren(['uid','displayName','text','sentAt']) && newData.child('text').isString() && newData.child('text').val().length >= 1 && newData.child('text').val().length <= 2000 && newData.child('sentAt').isNumber()"
          }
        }
      }
    },

    "userDMs": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$dmId": {
          ".write": "auth != null && (auth.uid === $uid || newData.child('otherUid').val() === auth.uid)",
          ".validate": "newData.hasChildren(['dmId','otherUid','lastAt']) && newData.child('dmId').isString() && newData.child('otherUid').isString() && newData.child('lastAt').isNumber()"
        }
      }
    }
  }
}
